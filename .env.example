# Frontend (Vite): se lee durante npm run build
VITE_API_URL=http://localhost:8000

# Backend: CORS, separa múltiples orígenes con coma
FRONTEND_ORIGINS=http://localhost:5173

# Backend: JWT; en producción usa un secreto largo y aleatorio
JWT_SECRET_KEY=change-me-with-a-long-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# Backend: PostgreSQL. Si no se configura, el backend usa SQLite local.
# DATABASE_URL=postgresql://worksheet:worksheet@localhost:5432/worksheet_builder

# Demo seed: por defecto se activa en SQLite y se desactiva en PostgreSQL.
# En producción déjalo en false.
SEED_DEMO_USERS=false
# DEMO_ADMIN_PASSWORD=admin123
# DEMO_TEACHER_PASSWORD=profesor123
# DEMO_STUDENT_PASSWORD=estudiante123
